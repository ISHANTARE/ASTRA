[flake8]
# ASTRA linting rules

# Respect PEP8: 79 char line length for library code
# (127 char override for readability in test/data config code)
max-line-length = 127

# Ignore long-imports in __init__ (justified when importing many public API symbols)
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    build,
    dist,
    *.egg-info,
    docs/apidoc,
    .eggs

# Ignore complexity warnings for now (can be re-enabled after audit)
max-complexity = 20

# Ignores (F401, F403, F811, E501, W503, E203)
ignore =
    F401,
    F403,
    F811,
    E501,
    W503,
    E203
